# NapCat WebSocket URL (e.g. ws://localhost:3001)
NAPCAT_WS_URL=ws://localhost:3001

# NapCat access token (set in NapCat config)
NAPCAT_ACCESS_TOKEN=

# No API key needed — uses Claude Code subscription via @anthropic-ai/claude-agent-sdk.
# Run `claude` CLI once to ensure you're logged in; the SDK reads those credentials.

# QQ account number of the bot — required for @-mention detection in lurker mode
BOT_QQ_ID=

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# SQLite database path (default: data/bot.db)
DB_PATH=data/bot.db

# Comma-separated group IDs the bot will participate in (for announcement sync, lore loading, etc.)
ACTIVE_GROUPS=484787509

# Node environment
NODE_ENV=development
