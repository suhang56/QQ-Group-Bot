# ============================================================================
# QQ-Group-Bot — environment variable reference (.env.example)
# ----------------------------------------------------------------------------
# Every var mentioned in src/ appears here. Defaults shown are what the code
# uses when the var is unset. Booleans are "1"/"true" vs "0"/"false" unless
# noted. Integers go through parseIntOr() so invalid values (e.g. "7d") fall
# back with a warning log instead of NaN.
# ============================================================================


# ---- Core runtime ----------------------------------------------------------
# NapCat WebSocket URL (e.g. ws://localhost:3001) — REQUIRED
NAPCAT_WS_URL=ws://localhost:3001
# NapCat access token (set in NapCat config). Optional unless NapCat requires it.
NAPCAT_ACCESS_TOKEN=
# QQ account number of the bot — REQUIRED for @-mention detection.
BOT_QQ_ID=
# Logging level: trace | debug | info | warn | error | fatal   (default: info)
LOG_LEVEL=info
# SQLite database path   (default: data/bot.db)
DB_PATH=data/bot.db
# Comma-separated group IDs the bot participates in. First entry is the "home"
# group used for tuning/announcements/ratings.
ACTIVE_GROUPS=484787509
# Node environment — affects pino transport selection. (default: development)
NODE_ENV=development


# ---- LLM provider selection / models --------------------------------------
# No API key needed for the main Claude path — uses the local `claude` CLI
# subscription via @anthropic-ai/claude-agent-sdk.

# Group chat reply + deflections + mimic + welcome + announcements.
CHAT_MODEL=claude-sonnet-4-6
# Image describe + image moderation. Gemini is ~3x faster than Claude Haiku.
VISION_MODEL=gemini-2.5-flash
# Text moderator (HIGH-volume: every non-command group message).
MODERATOR_MODEL=qwen3:8b
# Self-reflection loop (hourly tuning.md generator).
REFLECTION_MODEL=gemini-2.5-flash
# Opportunistic harvest + unknown-term resolver (every 15min + daily deep).
HARVEST_MODEL=qwen3:8b
# Alias miner (every 2h — group member nickname discovery).
ALIAS_MODEL=qwen3:8b
# Jargon miner (piggybacks on harvest cycle — group-specific slang).
JARGON_MODEL=qwen3:8b
# Lore updater (threshold-triggered, outputs full markdown doc).
LORE_MODEL=qwen3:8b
# Self-learning correction + harvest distillation.
LEARN_MODEL=qwen3:8b
# Online research path — needs WebSearch tool, stays on Claude.
RESEARCH_MODEL=claude-haiku-4-5-20251001
# Layered chat "fast path" (lurker-mode) model. See ChatModule._pickChatModel.
CHAT_QWEN_MODEL=qwen3:8b
# DeepSeek V3.2 — primary chat model for engaged paths (cost-optimized).
CHAT_DEEPSEEK_MODEL=deepseek-chat

# Ollama server endpoint.
OLLAMA_BASE_URL=http://localhost:11434
# Ollama presence flag. Set to "0" to force all qwen:* routes to Claude fallback.
OLLAMA_ENABLED=1
# Gemini — set this to an AI Studio key to enable the provider (also used for Gemini Grounding web lookup).
GEMINI_API_KEY=
# deprecated — no longer required (replaced by Gemini Grounding in Path C)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# DeepSeek — set to a platform.deepseek.com key to enable the provider.
DEEPSEEK_API_KEY=

# Kill switch: force ALL chat calls through RUNTIME_CHAT_MODEL (emergency rollback).
CHAT_QWEN_DISABLED=0
# Kill switch: fact semantic retrieval. "1" falls back to recency-based injection.
FACTS_RAG_DISABLED=0


# ---- Rating portal / moderation review (HTTP admin surface) ---------------
# Port for the rating + moderation review web UI.   (default: 4000)
RATING_PORT=4000
# Shared secret clients must send in the `X-Admin-Token` header. When unset
# the server starts in dev mode and logs a startup warning — DO NOT ship
# production without this set.
RATING_PORTAL_TOKEN=
# Comma-separated list of allowed browser Origins for state-changing requests
# (POST/PATCH). Use "*" to disable Origin checks (NOT recommended).
# Default when unset: http://localhost:${RATING_PORT}
RATING_PORTAL_ORIGINS=http://localhost:4000
# Admin user id that receives moderation approval DMs and can run
# /approve / /reject / /bot_status / etc.   (default: 2331924739)
MOD_APPROVAL_ADMIN=
# Comma-separated "<uid>:<groupId>,..." list of users allowed to hold
# free-form private chat with the bot (full ChatModule pipeline, using the
# bound group's lore/persona). Entries without `:<groupId>` are dropped.
# Empty default — no one can private-chat the bot.
PRIVATE_CHAT_USERS=
# Directory for /name_images captures.   (default: ./data/name-images)
NAME_IMAGES_DIR=


# ---- Persona patch self-reflection (M6.6 daily + M8.1 weekly) -------------
# Days a pending daily proposal stays listable in /persona_review.   (7)
PERSONA_PATCH_TTL_DAYS=7
# Max new proposals the scheduler may insert per group per UTC day.  (1)
PERSONA_PATCH_DAILY_CAP=1
# Scheduler period in ms.    (default: 86400000 = 24h)
PERSONA_PATCH_PERIOD_MS=86400000
# Offset from self-reflection timer so the two LLM calls don't collide.  (300000 = 5 min)
PERSONA_PATCH_OFFSET_MS=300000
# Kill switch — disable daily+weekly ticks entirely.
PERSONA_PATCH_DISABLED=0

# Weekly-cadence extension (M8.1):
# Max chars in weekly new_persona_text (daily is 8000).   (12000)
PERSONA_PATCH_WEEKLY_MAX_LEN=12000
# Min chars in weekly new_persona_text.   (200)
PERSONA_PATCH_WEEKLY_MIN_LEN=200
# Max chars in weekly reasoning (daily is 2000). Holds 4 bullet sections.  (3000)
PERSONA_PATCH_WEEKLY_REASONING_MAX=3000
# Max lines in weekly diff_summary (daily is 40).   (60)
PERSONA_PATCH_WEEKLY_DIFF_MAX_LINES=60
# Days a weekly pending proposal stays listable.   (14)
PERSONA_PATCH_WEEKLY_TTL_DAYS=14
# Kill switch — skip weekly ticks only (daily still runs).
PERSONA_PATCH_WEEKLY_DISABLED=0
# Min corpus size (messages in 7d window) before a weekly tick runs.   (50)
PERSONA_PATCH_WEEKLY_MIN_CORPUS=50
# Jaccard bigram similarity floor between new_persona_text[:200] and old.
# Below this, proposals are rejected as identity_drift_excessive.   (0.3)
PERSONA_PATCH_WEEKLY_IDENTITY_FLOOR=0.3


# ---- Proactive engine (idle-break / TOD-aware) ----------------------------
# Enable the proactive idle-breaker. Default: disabled.
PROACTIVE_ENGINE_ENABLED=0
# Tick interval in ms (min floor in code).   (60000 = 1 min)
PROACTIVE_ENGINE_TICK_MS=60000
# Minimum silence (in ms) before the group qualifies for a break.   (900000 = 15min)
PROACTIVE_ENGINE_IDLE_MIN_MS=900000
# Cooldown (in ms) after a successful proactive send.   (1800000 = 30min)
PROACTIVE_ENGINE_COOLDOWN_MS=1800000
# Min activity samples before TOD (time-of-day) prior kicks in.   (500)
PROACTIVE_ENGINE_TOD_MIN_SAMPLES=500
# How many top-activity hours (UTC) are eligible for proactive sends.   (6)
PROACTIVE_ENGINE_TOD_TOP_HOURS=6
# Max proactive sends per group per UTC day.   (3)
PROACTIVE_ENGINE_DAILY_CAP=3
# If "1" or "true" — log what WOULD be sent without actually sending.
PROACTIVE_ENGINE_DRYRUN=0


# ---- Scrapers / harvest / miners (background workers) ---------------------
# BanG Dream live scraper — set to "false" to disable.
BANDORI_SCRAPE_ENABLED=true
# Scrape interval in ms.   (86400000 = 24h)
BANDORI_SCRAPE_INTERVAL_MS=86400000
# Alias miner — set to "0" to disable.
ALIAS_MINER_ENABLED=1
# Opportunistic harvest — set to "0" to disable.
OPPORTUNISTIC_HARVEST_ENABLED=1
# Self-reflection (hourly tuning.md) — set to "0" to disable.
SELF_REFLECTION_ENABLED=1
# Self-learning online fact research — set to "0" to disable.
SELF_LEARN_ONLINE=1


# ---- Pre-chat judge + memes-v1 + vision -----------------------------------
# Pre-chat judge (qwen gate before Sonnet). Set to "1" to disable entirely.
PRE_CHAT_JUDGE_DISABLED=0
# Memes-v1 pipeline kill switch.
MEMES_V1_DISABLED=0
# Cosine similarity threshold for meme variant clustering.   (0.78)
MEME_CLUSTER_THRESHOLD=0.78
