{
  "name": "qq-group-bot",
  "version": "0.1.0",
  "description": "Intelligent QQ group bot with Claude AI, NapCat OneBot v11 adapter",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --testPathPattern=integration",
    "typecheck": "tsc --noEmit",
    "import-history": "tsx scripts/import-history.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5",
    "openai": "^6.34.0",
    "pino": "^9.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "ws": "^8.18.0"
  }
}
