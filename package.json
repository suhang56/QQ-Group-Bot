{
  "name": "qq-group-bot",
  "version": "0.1.0",
  "description": "Intelligent QQ group bot with Claude AI, NapCat OneBot v11 adapter",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--experimental-sqlite tsx src/index.ts",
    "start": "cross-env NODE_OPTIONS=--experimental-sqlite node dist/index.js",
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const src='src/server',dst='dist/server';fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))if(f.endsWith('.html'))fs.copyFileSync(path.join(src,f),path.join(dst,f));\"",
    "test": "cross-env NODE_OPTIONS=--experimental-sqlite vitest run --coverage",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-sqlite vitest",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-sqlite vitest run --testPathPattern=integration",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "import-history": "cross-env NODE_OPTIONS=--experimental-sqlite tsx scripts/import-history.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5",
    "node-html-parser": "^7.1.0",
    "openai": "^6.34.0",
    "pino": "^9.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.2",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "ws": "^8.18.0"
  }
}
